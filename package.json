{
  "name": "printnc-tool-library",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "worker:dev": "wrangler dev worker/index.ts --local",
    "worker:deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply printnc-tool-library --local",
    "db:migrate": "wrangler d1 migrations apply printnc-tool-library --remote",
    "check": "tsc -b"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "fflate": "^0.8.2",
    "lucide-react": "^0.561.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "typescript": "^5.9.3",
    "vite": "^7.2.7"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251223.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "wrangler": "^4.57.0"
  },
  "engines": {
    "node": ">=20.19.0",
    "pnpm": ">=10.0.0"
  }
}
